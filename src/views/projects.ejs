<%- include('partials/header') %>
<main>
    <h1><%= title %></h1>
    <p>Browse our current community service opportunities:</p>
    
    <ul>
        <% if (typeof projects !== 'undefined' && projects.length > 0) { %>
            <% projects.forEach(project => { %>
                <li>
                    <% 
                        const friendlyDate = new Date(project.date).toLocaleDateString('en-US', {
                            year: 'numeric',
                            month: 'long',
                            day: 'numeric'
                        });
                    %>
                    <span class="project-date" style="color: #666; font-size: 0.95rem;"><%= friendlyDate %>:</span>
                    
                    <a href="/project/<%= project.project_id %>">
                        <strong class="project-title" style="font-size: 1.3rem; display: block; margin: 4px 0;"><%= project.title %></strong>
                    </a>
                    
                    <em class="project-org" style="color: #2e7d32; display: block; margin-bottom: 8px;">
                        (<a href="/organization/<%= project.organization_id %>"><%= project.organization_name %></a>)
                    </em>
                    
                    <p><%= project.description %></p>
                    <small>📍 Location: <%= project.location %></small>
                </li>
            <% }) %>
        <% } else { %>
            <p>No service projects found.</p>
        <% } %>
    </ul>
</main>
<%- include('partials/footer') %>