<%- include('partials/header') %>

<main>
    <h1><%= title %></h1>
    <p>Browse our current community service opportunities:</p>
    
    <ul>
        <% if (typeof projects !== 'undefined' && projects.length > 0) { %>
            <% projects.forEach(project => { %>
                <li>
                    <% 
                        // Formata a data vinda do banco de dados (ex: "August 15, 2026")
                        const friendlyDate = new Date(project.date).toLocaleDateString('en-US', {
                            year: 'numeric',
                            month: 'long',
                            day: 'numeric'
                        });
                    %>
                    <em><%= friendlyDate %>:</em> <%= project.title %> <strong>🟢<%= project.organization_name %></strong>
                    <p><%= project.description %></p>
                    <small>📍 Location: <%= project.location %></small>
                </li>
            <% }) %>
        <% } else { %>
            <p>No service projects found.</p>
        <% } %>
    </ul>
</main>

<%- include('partials/footer') %>